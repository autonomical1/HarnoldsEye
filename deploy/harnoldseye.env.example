# Install: sudo cp deploy/harnoldseye.env.example /etc/harnoldseye.env && sudo chmod 640 /etc/harnoldseye.env
# Must include every browser Origin that will call the API (comma-separated, no spaces).
# Use scheme + host; add :port only when not 80/443. Replace the public IP with yours.
CORS_ORIGINS=http://66.42.120.203,http://127.0.0.1,http://localhost

# Optional: absolute path to model pickle if not beside backend/model/backend.py
# MODEL_PKL=/opt/HarnoldsEye/backend/model/model.pkl

# Per-IP limit on POST /api/scan (SlowAPI format)
SCAN_RATE_LIMIT=10/hour

# Classifier: snippets per forward pass (default 48; lower = steadier CPU, more batches).
# CLASSIFIER_BATCH_SIZE=48
# Embedding fallback: SentenceTransformer encode batch (default 32).
# ST_ENCODE_BATCH_SIZE=32
# PyTorch CPU matmul threads (optional; default min(cpu_count, 64)). Also respects OMP_NUM_THREADS.
# TORCH_NUM_THREADS=24

# Scan only .c/.cpp/.cc/.cxx (skip .h/.hpp/.hh)
# SCAN_INCLUDE_HEADERS=0

# When ML/percentile/classifier drops a chunk but it contains obvious strcpy/scanf/…,
# still send it to Gemini (default on). Fixes missing files in multi-file lab repos.
# SCAN_HEURISTIC_SINK_RESCUE=1
# Cap rescued snippets per scan (default 512)
# SCAN_HEURISTIC_SINK_MAX=512
# Require max(softmax/cosine) ≥ this (default 0.08); set SCAN_HEURISTIC_REQUIRE_MIN_SIM=0 to rescue all sink hits
# SCAN_HEURISTIC_MIN_SIMILARITY=0.08
# If Gemini is off, still emit heuristic hits (noisy; default 0)
# SCAN_HEURISTIC_WITHOUT_GEMINI=0

# Per-finding code window in API JSON + report UI (git-blame style; default 5 lines each side)
# REPORT_CONTEXT_LINES_BEFORE=5
# REPORT_CONTEXT_LINES_AFTER=5
# Max rows in one window after expansion (default 40)
# REPORT_CONTEXT_MAX_ROWS=40

# Snippet extraction: method = whole function/method (signature + { … }) [default]
# window = legacy overlapping line windows (uses SNIPPET_WINDOW_LINES / SNIPPET_LINE_STRIDE)
# SNIPPET_MODE=method

# If no )-before-{ functions are found, scan the whole file as one chunk (default on)
# SNIPPET_WHOLE_FILE_FALLBACK=1

# Small files (≤ SNIPPET_SMALL_FILE_MAX_LINES): split huge single-function bodies into
# overlapping windows so ML/Gemini see each region (e.g. long ConnectionHandler).
# SNIPPET_SUBDIVIDE_LARGE_FUNCTIONS=1
# SNIPPET_SMALL_FILE_MAX_LINES=600
# SNIPPET_SUBDIVIDE_MIN_LINES=80
# SNIPPET_SUBCHUNK_LINES=48
# SNIPPET_SUBCHUNK_STRIDE=24

# After verificajtion, add rows at out-of-body call sites for the same sink function (report UI).
# CALL_SITE_ATTRIBUTION=1

# Repo-wide ML score percentile (default 75; lower = more snippets → more Gemini calls). Skipped
# when the clone has fewer than ML_REPO_PERCENTILE_MIN_SNIPPETS snippets.
# ML_REPO_SCORE_PERCENTILE=75
# ML_REPO_PERCENTILE_MIN_SNIPPETS=250
# Classifier softmax floor / embedding cosine floor / top-vs-runner-up margin (defaults favor recall).
# ML_MIN_ABSOLUTE_SIMILARITY_CLASSIFIER=0.35
# ML_MIN_ABSOLUTE_SIMILARITY=0.78
# ML_MIN_CATEGORY_MARGIN=0.012
# Binary pickle classifier: only forward chunks predicted as this label (default LABEL_1).
# ML_CLASSIFIER_POSITIVE_LABEL=LABEL_1

# --- Google Gemini (final human-like review of ML-flagged chunks) ---
# Put your key in /etc/harnoldseye.env (or export before dev). Never commit the key.
# GEMINI_API_KEY=your_key_here
# Enable/disable final LLM gate (default 1 when key is set; set 0 to skip API calls)
# GEMINI_VERIFY=1
# Model id (override per your API; default in code is gemini-flash-latest).
# Fast / cheap: gemini-flash-latest, gemini-flash-lite-latest
# Richer labels & nuance (recommended when you see over-generic types): gemini-pro-latest, gemini-3-pro-preview
# Preview variants: gemini-3-flash-preview, gemini-3.1-pro-preview, etc. Skip *-image* / *customtools* for this JSON audit.
# GEMINI_MODEL=gemini-flash-latest
# GEMINI_MODEL=gemini-pro-latest
# Max characters of each chunk sent to Gemini (default 120000)
# GEMINI_MAX_CHUNK_CHARS=120000
# Milliseconds to sleep between API calls (rate limits; ignored when GEMINI_MAX_CONCURRENT>1)
# GEMINI_DELAY_MS=200
# Concurrent Gemini HTTP requests (default 16). Set 1 for strictly sequential. Lower if you hit 429s.
# GEMINI_MAX_CONCURRENT=16
# Ask for JSON-shaped output (default 1). Set 0 if your model/API rejects response_mime_type.
# GEMINI_JSON_RESPONSE=1
# Max tokens for Gemini reply (default 1024)
# GEMINI_MAX_OUTPUT_TOKENS=1024
# If Gemini says not vulnerable, still keep the ML chunk (default 0). Raises recall; more false positives.
# GEMINI_KEEP_ML_ON_REJECT=0
# Total Gemini round-trips = one per ML/heuristic chunk; for more chunks lower ML_REPO_SCORE_PERCENTILE or raise SCAN_HEURISTIC_SINK_MAX.
# On API/parse errors or unparseable JSON: drop = discard finding (default); keep = treat as vulnerable
# GEMINI_ON_ERROR=drop
# Log each request/response and usage_metadata to stderr (journalctl for systemd)
# GEMINI_DEBUG=1
# Gemini returns {"vulnerable", "line_numbers": [[start,end],...], "vulnerability_type": "..."}
# (types are shown on the report); ranges are clamped to the ML chunk.
# Default 1 = strict (production / large OSS): no extra lab/CTF instructions on top of core prompt.
# Set to 0 to append educational bias (extra recall on deliberate-vuln training repos).
# GEMINI_STRICT_SOURCE_CONTEXT=1

# --- NIST NVD CVE lookup (optional; adds related_cves[] per finding in report JSON) ---
# https://nvd.nist.gov/developers/request-an-api-key — key raises rate limit (recommended).
# Use plain values (no quotes) so systemd parses correctly: NVD_CVE_LOOKUP=1
# NVD_CVE_LOOKUP=0
# NVD_API_KEY=
# NVD_CVE_LIMIT=5
# Optional: limit to CVEs *published* in the last N days (1–120 only; NVD requires a
# paired start/end window). Default: no date filter; newest CVEs are preferred via sort.
# NVD_PUBLISHED_WINDOW_DAYS=0
# Seconds between NVD requests (default 0.7 if NVD_API_KEY set, else 6.5)
# NVD_REQUEST_DELAY_SEC=
